{
  "name": "OpenAI CPA",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "pip install --no-cache-dir -r requirements.txt",
  "forwardPorts": [
    8000
  ],
  "portsAttributes": {
    "8000": {
      "label": "OpenAI CPA Web",
      "onAutoForward": "openBrowser"
    }
  }
}