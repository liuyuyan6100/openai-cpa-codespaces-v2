{
  "name": "OpenAI CPA",
  "image": "mcr.microsoft.com/devcontainers/universal:2-linux",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [
    8000
  ],
  "portsAttributes": {
    "8000": {
      "label": "OpenAI CPA Web",
      "onAutoForward": "openBrowser"
    }
  }
}